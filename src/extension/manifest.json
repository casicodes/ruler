{
  "manifest_version": 3,
  "name": "Ruler",
  "version": "0.2.3",
  "description": "Floating alignment guides: cursor crosshairs, click to pin, color picker.",
  "permissions": ["tabs", "scripting", "windows"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Show or hide Ruler"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "ruler_toggle_ruler": {
      "suggested_key": { "default": "Alt+Shift+R" },
      "description": "Toggle ruler guides (works without clicking the page)"
    },
    "ruler_line_vertical": {
      "suggested_key": { "default": "Alt+Shift+V" },
      "description": "Vertical line mode"
    },
    "ruler_line_horizontal": {
      "suggested_key": { "default": "Alt+Shift+H" },
      "description": "Horizontal line mode"
    },
    "ruler_line_both": {
      "suggested_key": { "default": "Alt+Shift+B" },
      "description": "Both line modes"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
